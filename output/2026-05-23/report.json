  "version_update": {
    "version": "0.322.1",
    "release_date": "2026-05-23",
    "changes": [
      "Fixed a bug where upgraded fuel cell production facilities (Fuel Cell Assembly Line, Fuel Cell Fabrication Complex, Hydrogen Fuel Cell Plant, Pressurized Hydrogen Factory, Hydrogen Synthesis Hub) were consuming more fuel cells in maintenance than they produced, making them net-negative producers. They now produce fuel cells without consuming any.",
      "Fixed the same bug in the Argon Refinery Array and Argon Crystallization Tower, which were consuming purified argon as maintenance. They still consume fuel cells as a power source but no longer consume their own output."
    ]
  },
